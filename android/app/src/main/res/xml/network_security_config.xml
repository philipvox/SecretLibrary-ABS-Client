<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!--
      Allow cleartext (HTTP) to all hosts.
      This app connects to user-specified self-hosted AudiobookShelf servers
      which commonly run plain HTTP on local networks, VPNs (Tailscale, WireGuard),
      and custom ports. Restricting cleartext by domain/IP is not feasible
      because server addresses are arbitrary and user-defined.
    -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
